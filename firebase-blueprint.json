{
  "entities": {
    "anime": {
      "title": "Anime",
      "description": "An anime series catalog entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "synopsis": { "type": "string" },
        "coverImage": { "type": "string" },
        "bannerImage": { "type": "string" },
        "genres": { "type": "array" },
        "rating": { "type": "number" },
        "episodesCount": { "type": "number" },
        "status": { "type": "string" },
        "type": { "type": "string" },
        "releasedYear": { "type": "string" },
        "duration": { "type": "string" },
        "studio": { "type": "string" },
        "trailerUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title"]
    },
    "seasons": {
      "title": "Season",
      "description": "An anime season",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "animeId": { "type": "string" },
        "number": { "type": "number" },
        "title": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["animeId", "number"]
    },
    "episodes": {
      "title": "Episode",
      "description": "An episode of a season of an anime",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "animeId": { "type": "string" },
        "seasonId": { "type": "string" },
        "number": { "type": "number" },
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "videoUrl": { "type": "string" },
        "duration": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["animeId", "seasonId", "number"]
    },
    "users": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "contact_messages": {
      "title": "ContactMessage",
      "description": "User feedback or contact inquiry messages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "attachmentUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "userId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "isStarred": { "type": "boolean" },
        "isArchived": { "type": "boolean" },
        "ipAddress": { "type": "string" },
        "userAgent": { "type": "string" },
        "device": { "type": "string" },
        "os": { "type": "string" }
      },
      "required": ["name", "email", "subject", "message", "category", "priority"]
    }
  },
  "firestore": {
    "anime/{animeId}": {
      "schema": "anime",
      "description": "Anime catalog items"
    },
    "seasons/{seasonId}": {
      "schema": "seasons",
      "description": "Anime seasons"
    },
    "episodes/{episodeId}": {
      "schema": "episodes",
      "description": "Anime episodes"
    },
    "users/{userId}": {
      "schema": "users",
      "description": "Registered user accounts"
    },
    "contact_messages/{messageId}": {
      "schema": "contact_messages",
      "description": "User submitted contact or support messages"
    }
  }
}
